    <connection>olist_datawarehouse</connection>
    <sql>WITH t AS (
    SELECT
        o.order_id,
        o.order_status,
        o.record_hash,
        NULLIF(o.order_purchase_timestamp,          '') AS raw_purchase_ts,
        NULLIF(o.order_approved_at,                 '') AS raw_approved_ts,
        NULLIF(o.order_delivered_carrier_date,      '') AS raw_carrier_ts,
        NULLIF(o.order_delivered_customer_date,     '') AS raw_delivered_ts,
        NULLIF(o.order_estimated_delivery_date,     '') AS raw_estimated_ts
    FROM staging.stg_orders o
    WHERE o.order_id IS NOT NULL
),
ts AS (
    SELECT
        order_id,
        order_status,
        record_hash,
        NULLIF(raw_purchase_ts, 'NaN')::timestamp  AS order_purchase_timestamp,
        NULLIF(raw_approved_ts, 'NaN')::timestamp  AS order_approved_at,
        NULLIF(raw_carrier_ts,  'NaN')::timestamp  AS order_delivered_carrier_date,
        NULLIF(raw_delivered_ts,'NaN')::timestamp  AS order_delivered_customer_date,
        NULLIF(raw_estimated_ts,'NaN')::timestamp  AS order_estimated_delivery_date
    FROM t
)
SELECT
    order_id,
    order_status,
    order_purchase_timestamp,
    order_approved_at,
    order_delivered_carrier_date,
    order_delivered_customer_date,
    order_estimated_delivery_date,
    -- approval_delay_hours
    CASE 
        WHEN order_approved_at IS NOT NULL 
         AND order_purchase_timestamp IS NOT NULL THEN
            FLOOR(
                EXTRACT(EPOCH FROM (order_approved_at - order_purchase_timestamp)) / 3600
            )::INTEGER
        ELSE 0
    END AS approval_delay_hours,
    -- delivery_delay_days = delivered - estimated
    CASE 
        WHEN order_delivered_customer_date IS NOT NULL
         AND order_estimated_delivery_date IS NOT NULL THEN
            (order_delivered_customer_date::date - order_estimated_delivery_date::date)
        ELSE 0
    END AS delivery_delay_days,
    -- total_delivery_days = delivered - purchase
    CASE 
        WHEN order_delivered_customer_date IS NOT NULL
         AND order_purchase_timestamp IS NOT NULL THEN
            (order_delivered_customer_date::date - order_purchase_timestamp::date)
        ELSE 0
    END AS total_delivery_days,
    -- on time?
    CASE 
        WHEN order_delivered_customer_date IS NOT NULL
         AND order_estimated_delivery_date IS NOT NULL
         AND (order_delivered_customer_date::date - order_estimated_delivery_date::date) &lt;= 0
            THEN TRUE
        ELSE FALSE
    END AS is_delivered_on_time,
    -- performance category
    CASE
        WHEN (order_delivered_customer_date IS NOT NULL
          AND order_estimated_delivery_date IS NOT NULL) THEN
            CASE 
                WHEN (order_delivered_customer_date::date - order_estimated_delivery_date::date) &lt; -5
                    THEN 'Early'
                WHEN (order_delivered_customer_date::date - order_estimated_delivery_date::date) &lt;= 0
                    THEN 'On Time'
                WHEN (order_delivered_customer_date::date - order_estimated_delivery_date::date) &lt;= 5
                    THEN 'Slightly Late'
                ELSE 'Very Late'
            END
        ELSE 'Unknown'
    END AS delivery_performance_category,
    record_hash,
    NOW() AS created_date,
    NOW() AS updated_date
FROM ts;
</sql>
