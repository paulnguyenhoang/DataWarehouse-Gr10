# ============================================================================
# KEEP THESE FILES (NEGATION PATTERNS)
# ============================================================================
# Always keep .gitkeep files to maintain empty directory structure


# Keep essential documentation
!README.md
!CHANGELOG.md
!LICENSE
!CONTRIBUTING.md

# Keep configuration templates (without actual secrets)
!config.template.*
!.env.example
!.env.template

# Keep SQL schema files (structure only, no data)
!sql/create_*.sql
!sql/schema_*.sql
!sql/migrations/*.sql

# Keep essential project files
!requirements.txt
!setup.py
!pyproject.toml
!Pipfile

# ============================================================================
# END OF GITIGNORE
# ============================================================================
